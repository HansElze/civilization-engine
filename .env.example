# Cuttlefish Civilization Engine - Environment Configuration
# Copy to .env and customize for your deployment

# Constitutional Framework
CONSTITUTION_VERSION=1.2
GOVERNANCE_MODE=strict
TRUST_DECAY_RATE=0.05

# Agent Configuration  
DEFAULT_TRUST_THRESHOLD=50.0
MAX_AGENT_INSTANCES=10
AGENT_TIMEOUT_SECONDS=300

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cuttlefish
POSTGRES_USER=cuttlefish
POSTGRES_PASSWORD=change-this-in-production

# Vector Database (Qdrant)
QDRANT_URL=http://vector-db:6333
QDRANT_GRPC_PORT=6334
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DIMENSION=384

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_DB=0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=300

# Security & Authentication
JWT_SECRET=change-this-in-production-32-chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ENCRYPTION_KEY=change-this-32-character-key-prod
BCRYPT_ROUNDS=12

# Trust & Governance
TRUST_SCORE_DEFAULT=50.0
TRUST_SCORE_DECAY_DAYS=7
ADVERSARIAL_THRESHOLD=20.0
CONSTITUTIONAL_VIOLATION_PENALTY=-50

# Knowledge & RAG Configuration
MAX_RAG_RESULTS=20
RAG_SIMILARITY_THRESHOLD=0.7
DOCUMENT_CHUNK_SIZE=512
DOCUMENT_OVERLAP=50

# Monitoring & Observability
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
LOG_LEVEL=INFO
METRICS_PORT=9090

# Feature Flags
DEBUG_MODE=false
DEV_MODE=false
CONSTITUTIONAL_STRICT_MODE=true
TRUST_GRAPH_ENABLED=true
OBSERVATIONAL_MEMORY_ENABLED=true

# External Integrations (Optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=

# SMTP Configuration (for notifications)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# Discord Bot (optional)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=

# Development Only
MOCK_EMBEDDINGS=false
SKIP_MIGRATIONS=false
SEED_DATA=false